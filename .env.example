# متغيرات البيئة لتطبيق أرشيف المستندات

# MongoDB Configuration (مطلوب للنشر السحابي)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/document-archiver?retryWrites=true&w=majority
MONGODB_DB=document-archiver

# NextAuth Configuration (مطلوب للمصادقة)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Application Configuration
NODE_ENV=development
PORT=3000

# مسار قاعدة البيانات المحلي (للتطوير المحلي فقط)
# DB_PATH=./db/local.json

# عنوان URL الأساسي للتطبيق (للإنتاج)
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: Redis for caching (موصى به للإنتاج)
# REDIS_URL=redis://localhost:6379

# Optional: Email for notifications (اختياري للإشعارات)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

