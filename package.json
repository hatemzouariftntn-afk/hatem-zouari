{
  "name": "document-archiver-web-lowdb",
  "version": "1.0.2",
  "description": "تطبيق أرشفة المستندات باستخدام LowDB",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postbuild": "echo 'Build completed successfully'",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "electron-builder --win --publish=never",
    "icons": "node generate-icons.js",
    "dist": "npm run icons && npm run build && npm run electron:build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@next-auth/mongodb-adapter": "^1.1.3",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "cloudinary": "^2.9.0",
    "jszip": "^3.10.1",
    "lowdb": "^7.0.1",
    "mongodb": "^5.9.2",
    "next": "^14.0.0",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "resend": "^6.9.3",
    "typescript": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "concurrently": "^9.2.1",
    "electron": "^38.2.2",
    "electron-builder": "^26.0.12",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "fs-extra": "^11.1.1",
    "jimp": "^1.6.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "wait-on": "^9.0.1"
  },
  "keywords": [
    "document",
    "archiver",
    "lowdb",
    "nextjs",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.archivemanager.app",
    "productName": "Archive Manager",
    "directories": {
      "output": "dist-build"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "assets/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "asar": false,
    "forceCodeSigning": false,
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Archive Manager",
      "artifactName": "ArchiveManager-Setup-${version}.${ext}"
    },
    "afterPack": "./scripts/afterPack.js"
  }
}
